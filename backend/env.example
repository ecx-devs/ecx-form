# ===========================================
# ECX Forms Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# Server Configuration
PORT=3001
NODE_ENV=development

# Supabase Configuration
# Get these from your Supabase project settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# CORS Configuration
# Frontend URL for CORS whitelist
FRONTEND_URL=http://localhost:3000

# Backend URL (used for keep-alive self-ping in production)
# Set this to your deployed Render URL, e.g. https://ecx-forms-api.onrender.com
BACKEND_URL=

# File Upload Configuration
MAX_FILE_SIZE_MB=2

# Google Sheets Export
# Create a Google Cloud service account, enable Google Sheets API + Google Drive API,
# and store the private key with escaped newlines (\n) in Render.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
# Optional: automatically share newly created sheets with this email.
GOOGLE_SHEETS_SHARE_EMAIL=
GOOGLE_SHEETS_SHARE_ROLE=writer
# Optional but recommended: Shared Drive root ID or folder ID where sheets should be created.
GOOGLE_DRIVE_PARENT_ID=
